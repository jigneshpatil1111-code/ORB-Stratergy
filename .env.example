# ============================================
# ORB Intraday Trading System - Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# --- Dhan Broker API Credentials ---
# Get these from https://dhanhq.co/ after creating an app
DHAN_CLIENT_ID=your_client_id_here
DHAN_ACCESS_TOKEN=your_access_token_here

# --- Telegram Notifications ---
# Create a bot via @BotFather and get the token
# Get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Capital & Risk Management ---
# Base capital in INR (without leverage)
BASE_CAPITAL=5000
# Leverage multiplier (effective capital = BASE_CAPITAL * LEVERAGE)
LEVERAGE=5
# Maximum ORB candle range as % of close price (reject if higher)
MAX_RANGE_PCT=1.5
# Minimum stock price filter (skip penny stocks)
MIN_STOCK_PRICE=60
# Maximum stock price filter (skip expensive stocks)
MAX_STOCK_PRICE=1000

# --- Trading Mode ---
# Set to 'false' for live trading with real orders
PAPER_TRADING=false
# Maximum quantity per trade (set to 1 for safe testing)
MAX_QTY_PER_TRADE=1

# --- Security ---
# Secret key for webhook authentication
WEBHOOK_SECRET=your_webhook_secret
# Password for the Streamlit dashboard
DASHBOARD_PASSWORD=admin123

# --- Storage ---
# Path to SQLite database file (relative to project root)
DB_PATH=data/trades.db

# --- Logging ---
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
